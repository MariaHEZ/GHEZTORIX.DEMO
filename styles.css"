body{
  margin:0;
  font-family: Arial;
  background:#eef2f7;
}

/* LOGIN */
.login-container{
  display:flex;
  justify-content:center;
  align-items:center;
  height:100vh;
}

.login-box{
  background:white;
  padding:30px;
  border-radius:10px;
  width:300px;
  box-shadow:0 10px 25px rgba(0,0,0,0.1);
  text-align:center;
}

input{
  width:90%;
  padding:10px;
  margin:10px 0;
  border:1px solid #ccc;
  border-radius:6px;
}

button{
  padding:10px;
  width:100%;
  background:#1f3c88;
  color:white;
  border:none;
  border-radius:6px;
  cursor:pointer;
}

button:hover{
  background:#162a5a;
}

/* DASHBOARD */
.hidden{ display:none; }

#dashboard{
  display:flex;
}

/* SIDEBAR */
.sidebar{
  width:220px;
  background:#1f3c88;
  color:white;
  height:100vh;
  padding:20px;
}

.sidebar button{
  margin-top:10px;
  width:100%;
  background:transparent;
  border:1px solid rgba(255,255,255,0.3);
}

/* MAIN */
.main{
  flex:1;
  padding:20px;
}

/* CARDS */
.cards{
  display:flex;
  gap:10px;
}

.card{
  background:white;
  padding:20px;
  border-radius:10px;
  flex:1;
  box-shadow:0 5px 15px rgba(0,0,0,0.05);
  text-align:center;
}

/* TABLE */
table{
  width:100%;
  background:white;
  border-collapse:collapse;
  margin-top:20px;
}

th, td{
  padding:10px;
  border-bottom:1px solid #ddd;
}

th{
  background:#f5f7fa;
}
