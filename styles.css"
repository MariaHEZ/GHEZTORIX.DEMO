body{
  margin:0;
  font-family:Arial;
  background:#f4f6f9;
}

/* LOGIN */
.center{
  display:flex;
  justify-content:center;
  align-items:center;
  height:100vh;
}

.cardLogin{
  background:white;
  padding:30px;
  width:300px;
  text-align:center;
  border-radius:10px;
  box-shadow:0 10px 25px rgba(0,0,0,0.1);
}

input, select{
  width:90%;
  padding:10px;
  margin:8px 0;
}

button{
  padding:10px;
  width:100%;
  background:#1d3557;
  color:white;
  border:none;
  cursor:pointer;
}

/* APP */
.hidden{display:none;}

#app{
  display:flex;
}

/* SIDEBAR */
.sidebar{
  width:220px;
  background:#1d3557;
  color:white;
  height:100vh;
  padding:15px;
}

.sidebar button{
  background:transparent;
  border:1px solid rgba(255,255,255,0.2);
  margin-top:10px;
}

/* MAIN */
.main{
  flex:1;
  padding:20px;
}

/* GRID */
.grid{
  display:flex;
  gap:10px;
}

.box{
  background:white;
  padding:20px;
  flex:1;
  border-radius:10px;
}

/* FORM */
.form{
  background:white;
  padding:15px;
  border-radius:10px;
  margin-bottom:20px;
}

/* TABLE */
table{
  width:100%;
  background:white;
  border-collapse:collapse;
}

th, td{
  padding:10px;
  border-bottom:1px solid #ddd;
}
