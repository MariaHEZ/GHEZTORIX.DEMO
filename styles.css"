body{

font-family:Arial;
background:#eef2f7;
margin:0;

}



.login{

width:300px;
margin:150px auto;
background:white;
padding:30px;
border-radius:15px;
text-align:center;

}


input{

width:90%;
padding:10px;
margin:8px;

}



button{

padding:10px;
background:#1d3557;
color:white;
border:none;
cursor:pointer;

}



.hidden{

display:none;

}



header{

background:#1d3557;
color:white;
padding:20px;
display:flex;
justify-content:space-between;

}



.cards{

display:grid;
grid-template-columns:repeat(4,1fr);
gap:20px;
padding:30px;

}



.icon{

background:white;
padding:30px;
border-radius:15px;
text-align:center;
cursor:pointer;
font-size:30px;

box-shadow:0 5px 15px #ccc;

}



.modulo{

background:white;
margin:30px;
padding:20px;
border-radius:15px;

}



table{

width:100%;

}


td{

padding:10px;
border-bottom:1px solid #ddd;

}
