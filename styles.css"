*{
    box-sizing:border-box;
}


body{

    margin:0;
    font-family:'Segoe UI',Arial,sans-serif;
    background:#f4f7fb;
    color:#333;

}


/* ================= LOGIN ================= */


#loginPage{

    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;

    background:
    linear-gradient(135deg,#1d3557,#457b9d);

}



.login-card{

    background:white;
    width:380px;
    padding:40px;

    border-radius:20px;

    text-align:center;

    box-shadow:
    0 20px 40px rgba(0,0,0,.25);

}



.login-card h1{

    color:#1d3557;

}



.login-card p{

    color:#777;
    margin-bottom:25px;

}




input,select{

    width:100%;
    padding:13px;

    margin:8px 0;

    border-radius:10px;

    border:1px solid #ddd;

    outline:none;

}



input:focus{

    border-color:#457b9d;

}





button{

    width:100%;

    padding:13px;

    margin-top:10px;

    border:none;

    border-radius:10px;

    cursor:pointer;

    background:#1d3557;

    color:white;

    font-size:15px;

}



button:hover{

    background:#457b9d;

}




/* ================= DASHBOARD ================= */


.hidden{

    display:none!important;

}



#dashboard{

    display:flex;

    height:100vh;

}





/* MENU LATERAL */


.sidebar{


    width:250px;

    background:#102542;

    color:white;

    padding:25px 15px;


}



.sidebar h2{

    text-align:center;

    margin-bottom:30px;

}




.sidebar button{

    background:transparent;

    text-align:left;

    margin-bottom:12px;

    border-radius:12px;

}



.sidebar button:hover{

    background:#1d3557;

}







/* CONTENIDO */


main{

    flex:1;

    padding:30px;

    overflow:auto;

}




.pantalla{

    background:white;

    padding:30px;

    border-radius:20px;


    box-shadow:

    0 10px 25px rgba(0,0,0,.08);


}







/* TARJETAS */


.cards{

    display:grid;

    grid-template-columns:
    repeat(auto-fit,minmax(220px,1fr));

    gap:20px;

    margin-top:20px;

}





.card{


    background:white;

    padding:25px;

    border-radius:20px;


    box-shadow:
    0 8px 20px rgba(0,0,0,.08);


    text-align:center;

    font-size:18px;

}





.card h2{

    font-size:35px;

    color:#1d3557;

}





/* TABLAS */


table{

    width:100%;

    margin-top:20px;

    border-collapse:collapse;

}




td,th{

    padding:14px;

    border-bottom:1px solid #ddd;

}



th{

    background:#f0f4fa;

}





/* REPORTES */


#reporte{

    margin-top:20px;

    padding:20px;

    background:#eef5ff;

    border-radius:15px;

}





/* RESPONSIVE */


@media(max-width:800px){


#dashboard{

    flex-direction:column;

}


.sidebar{

    width:100%;

    height:auto;

}


}
